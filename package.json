{
  "name": "get-z-index",
  "version": "2.0.0",
  "license": "MIT",
  "author": "andrewbeletskiy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whiteand/get-z-index.git"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "module": "dist/get-z-index.esm.js",
  "typings": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "tsdx dev",
    "build": "tsdx build",
    "test": "vitest .",
    "lint": "oxlint .",
    "format": "tsdx format",
    "typecheck": "tsdx typecheck",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^12.1.0",
    "@typescript/typescript6": "^6.0.2",
    "@vitest/coverage-v8": "4.1.10",
    "bunchee": "^6.12.0",
    "jsdom": "^29.1.1",
    "oxlint": "^1.74.0",
    "size-limit": "^12.1.0",
    "tsdx": "^2.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run lint"
    }
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "size-limit": [
    {
      "path": "dist/get-z-index.esm.js",
      "limit": "10 KB"
    }
  ],
  "engines": {
    "node": ">=10"
  }
}
